<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Digital Wallet Application</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

<style>
body{
    background:#f5f5f5;
}

.wallet-card{
    max-width:500px;
    margin:50px auto;
}

.balance-box{
    background:#198754;
    color:white;
    padding:20px;
    border-radius:10px;
    text-align:center;
}
</style>
</head>
<body>

<div class="container">
    <div class="card shadow wallet-card">
        <div class="card-body">

            <h2 class="text-center mb-4">💰 Digital Wallet</h2>

            <div class="balance-box">
                <h4>Available Balance</h4>
                <h2 id="balance">₹1000</h2>
            </div>

            <div class="mt-4">
                <input type="number" id="amount"
                    class="form-control"
                    placeholder="Enter Amount">
            </div>

            <div class="d-grid gap-2 mt-3">
                <button class="btn btn-success" onclick="addMoney()">
                    Add Money
                </button>

                <button class="btn btn-danger" onclick="withdrawMoney()">
                    Withdraw Money
                </button>
            </div>

            <hr>

            <h4>Transaction History</h4>

            <ul class="list-group" id="history">
                <li class="list-group-item">
                    Wallet Created with ₹1000
                </li>
            </ul>

        </div>
    </div>
</div>

<script>

let balance = 1000;

function updateBalance(){
    document.getElementById("balance").innerHTML = "₹" + balance;
}

function addHistory(message){
    let li = document.createElement("li");
    li.className = "list-group-item";
    li.innerHTML = message;

    document.getElementById("history").prepend(li);
}

function addMoney(){

    let amount =
    Number(document.getElementById("amount").value);

    if(amount <= 0){
        alert("Please enter a valid amount");
        return;
    }

    balance += amount;

    updateBalance();

    addHistory("✅ Added ₹" + amount);

    document.getElementById("amount").value = "";
}

